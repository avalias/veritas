/// Tests for the universal Web Credential verifier (veritas::credential).
/// The ES256 vector is REAL P-256/SHA-256 (the scheme C2PA Content
/// Credentials use), generated by dispute/tests/gen_credential_vectors.py
/// and verified here on-chain via Sui-native ecdsa_r1 — proving the news
/// industry's signing standard is admissible with no off-chain trust.
#[test_only]
module veritas::credential_tests;

use veritas::credential;

#[test]
fun es256_c2pa_vector_verifies_natively() {
    let pubkey = x"03236b008fd501e1ae306281f6743efaaff5864f4a6864839d589effb20c92d1b8";
    let message = x"41502050686f746f3a20537461727368697020636f6d706c6574657320736f6674206c616e64696e672c20323032362d30392d32385431343a30335a3b207368613235363d32633836343864313033653364643761643837363630646130663132366131343433623664323161633162643365633030306335653234653233373361393063";
    let sig = x"9fde825902e107ca3c8774abec9b335c2f9f5162d43a20db549597c558a2559e164365dabc718b9033e683860a35516aea61dcaaab3af659391027c1a8f446b4";
    // scheme 1 = ES256 / C2PA, dispatched to ecdsa_r1::secp256r1_verify
    assert!(credential::verify(credential::scheme_es256(), &pubkey, &message, &sig), 0);

    // a single tampered message byte must NOT verify
    let mut bad = message;
    *&mut bad[0] = 0x42;
    assert!(!credential::verify(credential::scheme_es256(), &pubkey, &bad, &sig), 1);
}

#[test]
fun native_scheme_predicate() {
    assert!(credential::is_native(credential::scheme_ed25519()), 0);
    assert!(credential::is_native(credential::scheme_es256()), 1);
    assert!(!credential::is_native(credential::scheme_rsa2048()), 2); // DKIM via Groth16, not here
}

#[test]
#[expected_failure(abort_code = 1, location = veritas::credential)]
fun rsa_scheme_aborts_on_chain() {
    // RSA/DKIM is admitted via a Groth16 proof off this path; calling
    // verify() with it must abort, never silently pass.
    let k = x"00";
    credential::verify(credential::scheme_rsa2048(), &k, &k, &k);
}
